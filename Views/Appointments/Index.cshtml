@model IEnumerable<SmartClinic.Models.Appointment>
@{
    ViewData["Title"] = "Appointments";
    bool isDoctor  = ViewData["IsDoctor"] as bool? ?? false;
    bool isPatient = ViewData["IsPatient"] as bool? ?? false;
    bool isAdmin   = ViewData["IsAdmin"] as bool? ?? false;
    bool canManage = !isDoctor && !isPatient; // Admin & Reception can create/delete
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="bi bi-calendar2-check-fill text-success me-2"></i>
            @(isDoctor ? "My Schedule" : isPatient ? "My Appointments" : "Appointments")
        </h2>
        @if (canManage)
        {
            <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
                <i class="bi bi-calendar-plus-fill me-1"></i>New Appointment
            </a>
        }
    </div>

    @if (isPatient)
    {
        <div class="alert alert-info border-0 shadow-sm rounded-3 mb-4">
            <i class="bi bi-info-circle-fill me-2"></i>
            Showing your personal appointments only. Contact reception to book or cancel.
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
        <form asp-action="Index" method="get" class="mb-4">
            <div class="row g-3 align-items-center">
                <div class="col-md-4">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                           class="form-control rounded-pill bg-light border-0 px-4" 
                           placeholder="Search by patient or doctor..." />
                </div>
                <div class="col-md-3">
                    <input type="date" name="dateFilter" value="@ViewData["DateFilter"]" 
                           class="form-control rounded-pill bg-light border-0 px-4" title="Search by Appointment Date" />
                </div>
                <div class="col-md-2">
                    <select name="statusFilter" class="form-select rounded-pill bg-light border-0 px-4">
                        <option value="">All Statuses</option>
                        <option value="Scheduled">Scheduled</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-dark rounded-pill px-4">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Clear</a>
                </div>
            </div>
        </form>

        <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Patient</th>
                            <th>Doctor</th>
                            <th>Date &amp; Time</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold ps-4">@item.Patient?.Name</td>
                                <td><span class="text-muted">Dr. @item.Doctor?.Name</span></td>
                                <td>@item.AppointmentDate.ToString("ddd, MMM d yyyy — h:mm tt")</td>
                                <td>
                                    @{
                                        var badgeClass = item.Status switch
                                        {
                                            "Completed" => "bg-success",
                                            "Cancelled"  => "bg-danger",
                                            _            => "bg-warning text-dark"
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill">@item.Status</span>
                                </td>
                                <td class="text-end pe-3">
                                    @* Doctor: Update Status buttons *@
                                    @if (isDoctor && item.Status == "Scheduled")
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="Completed" />
                                            <button type="submit" class="btn btn-sm btn-success rounded-pill me-1">
                                                <i class="bi bi-check-circle me-1"></i>Complete
                                            </button>
                                        </form>
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="status" value="Cancelled" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill">
                                                <i class="bi bi-x-circle me-1"></i>Cancel
                                            </button>
                                        </form>
                                    }
                                    @* Admin & Reception: Delete button *@
                                    else if (canManage)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill"
                                                data-bs-toggle="modal" data-bs-target="#delModal-@item.Id">
                                            <i class="bi bi-trash me-1"></i>Cancel
                                        </button>

                                        <div class="modal fade" id="delModal-@item.Id" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-0 shadow-lg">
                                                    <div class="modal-header bg-danger text-white border-0">
                                                        <h5 class="modal-title"><i class="bi bi-exclamation-octagon-fill me-2"></i>Cancel Appointment</h5>
                                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Cancel appointment for <strong>@item.Patient?.Name</strong>
                                                        on <strong>@item.AppointmentDate.ToString("MMMM d, yyyy")</strong>?
                                                    </div>
                                                    <div class="modal-footer border-0">
                                                        <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Go Back</button>
                                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn btn-danger rounded-pill">Confirm Cancel</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    @* Patient: read-only *@
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>No appointments found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .table-hover tbody tr:hover { background-color: #f8f9ff; }
</style>
