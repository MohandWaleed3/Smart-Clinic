@model SmartClinic.Models.Appointment
@{ ViewData["Title"] = "New Appointment"; }

<div class="container mt-4 fade-in">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card glass-card border-0 shadow-lg">
                <div class="card-header bg-gradient-success text-white border-0 p-4 rounded-top">
                    <h3 class="mb-0"><i class="bi bi-calendar-plus-fill"></i> Schedule Appointment</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PatientId" class="form-label fw-bold">Patient</label>
                                <select asp-for="PatientId" class="form-select glass-input" asp-items="ViewBag.PatientId"></select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DoctorId" class="form-label fw-bold">Assign Doctor</label>
                                <select asp-for="DoctorId" class="form-select glass-input" asp-items="ViewBag.DoctorId"></select>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="AppointmentDate" class="form-label fw-bold">Date and Time</label>
                                <input asp-for="AppointmentDate" type="datetime-local" class="form-control glass-input" />
                                <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-bold">Status</label>
                                <select asp-for="Status" class="form-select glass-input">
                                    <option value="Scheduled">Scheduled</option>
                                    <option value="Confirmed">Confirmed</option>
                                    <option value="Completed">Completed</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancel</a>
                            <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm rounded-pill">Book Now</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
