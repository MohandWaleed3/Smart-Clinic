@model SmartClinic.Models.Patient
@{
    ViewData["Title"] = "New Patient";
}

<div class="container mt-4 fade-in">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-lg">
                <div class="card-header bg-primary text-white border-0 p-4">
                    <h3 class="mb-0"><i class="bi bi-person-plus"></i> Secure Registration</h3>
                    <p class="mb-0 text-white-50 small">All inputs are sanitized and validated.</p>
                </div>
                <div class="card-body p-4 bg-light">
                    <form asp-action="Create" method="post">
                        <!-- CSRF Token automatically included by ASP.NET Core MVC -->
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row g-3">
                            <div class="col-md-6 form-floating mb-3">
                                <input asp-for="Name" class="form-control" placeholder="Full Name" />
                                <label asp-for="Name" class="ms-2">Full Name</label>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-floating mb-3">
                                <input asp-for="Code" class="form-control" placeholder="Patient Code" />
                                <label asp-for="Code" class="ms-2">Patient Code</label>
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6 form-floating mb-3">
                                <input asp-for="DateOfBirth" class="form-control" placeholder="Date of Birth" />
                                <label asp-for="DateOfBirth" class="ms-2">Date of Birth</label>
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 form-floating mb-3">
                                <input asp-for="Phone" class="form-control" placeholder="Phone Number" />
                                <label asp-for="Phone" class="ms-2">Phone Number</label>
                                <span asp-validation-for="Phone" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4"><i class="bi bi-arrow-left"></i> Back</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold shadow-sm"><i class="bi bi-save"></i> Save Record</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
