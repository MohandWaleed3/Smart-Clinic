@model IEnumerable<SmartClinic.Models.Patient>
@{
    ViewData["Title"] = "Patient Registry";
}

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill text-info"></i> Patient Registry</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-plus-lg"></i> New Patient</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body bg-light rounded">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label for="searchString" class="col-form-label fw-bold">Search</label>
                </div>
                <div class="col-md-6">
                    <input type="text" id="searchString" name="searchString" class="form-control" value="@ViewData["CurrentFilter"]" placeholder="Search by name or code..." />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-dark"><i class="bi bi-search"></i> Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Grid -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Code)</th>
                            <th>@Html.DisplayNameFor(model => model.DateOfBirth)</th>
                            <th>@Html.DisplayNameFor(model => model.Phone)</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="fw-bold ps-3">@Html.DisplayFor(modelItem => item.Name)</td>
                                <td><span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.Code)</span></td>
                                <td>@item.DateOfBirth.ToShortDateString()</td>
                                <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                                <td class="text-end pe-3">
                                    <button type="button" class="btn btn-sm btn-outline-danger shadow-sm" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>

                                    <!-- Delete Confirmation Dialog -->
                                    <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
                                      <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow">
                                          <div class="modal-header bg-danger text-white border-0">
                                            <h5 class="modal-title" id="deleteModalLabel"><i class="bi bi-exclamation-triangle-fill"></i> Confirm Deletion</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                          </div>
                                          <div class="modal-body text-start">
                                            Are you sure you want to completely delete the record for <strong>@item.Name</strong>? This action cannot be undone.
                                          </div>
                                          <div class="modal-footer border-0 bg-light">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-danger">Yes, Delete Securely</button>
                                            </form>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .table-hover tbody tr:hover { background-color: #f8f9fa; transform: scale(1.001); transition: all 0.2s; }
</style>
