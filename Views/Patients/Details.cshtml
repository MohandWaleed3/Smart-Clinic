@model SmartClinic.Models.Patient
@{ ViewData["Title"] = "Patient Details"; }

<div class="container mt-4 fade-in" style="max-width:560px">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Patients
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-secondary text-white border-0 py-3 rounded-top">
            <h5 class="mb-0"><i class="bi bi-person-vcard me-2"></i>Patient Details</h5>
        </div>
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Full Name</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                <dt class="col-sm-4 text-muted">Patient Code</dt>
                <dd class="col-sm-8"><span class="badge bg-secondary rounded-pill">@Model.Code</span></dd>

                <dt class="col-sm-4 text-muted">Date of Birth</dt>
                <dd class="col-sm-8">@Model.DateOfBirth.ToLongDateString()</dd>

                <dt class="col-sm-4 text-muted">Phone</dt>
                <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Phone) ? "—" : Model.Phone)</dd>
            </dl>
        </div>
    </div>
</div>

<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
