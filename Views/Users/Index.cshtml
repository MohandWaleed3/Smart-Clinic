@model IEnumerable<SmartClinic.Models.User>
@{ ViewData["Title"] = "System Users"; }

<div class="container mt-4 fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill text-primary"></i> System Users</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm"><i class="bi bi-person-plus-fill"></i> Add User</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card glass-card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-6">
                    <input type="text" name="searchString" class="form-control rounded-pill glass-input" value="@ViewData["CurrentFilter"]" placeholder="Search by name, code, or role..." />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-dark rounded-pill px-4 shadow-sm"><i class="bi bi-search"></i> Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card glass-card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 custom-table">
                    <thead class="table-light">
                        <tr>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Code)</th>
                            <th>@Html.DisplayNameFor(model => model.Role)</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td class="fw-bold ps-3">@Html.DisplayFor(modelItem => item.Name)</td>
                                <td><span class="badge bg-secondary">@Html.DisplayFor(modelItem => item.Code)</span></td>
                                <td><span class="badge bg-info text-dark shadow-sm">@Html.DisplayFor(modelItem => item.Role)</span></td>
                                <td class="text-end pe-3">
                                    <button type="button" class="btn btn-sm btn-outline-danger shadow-sm rounded-pill" data-bs-toggle="modal" data-bs-target="#deleteModal-@item.Id">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                    <!-- Delete Modal -->
                                    <div class="modal fade" id="deleteModal-@item.Id" tabindex="-1">
                                      <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow-lg glass-card">
                                          <div class="modal-header bg-danger text-white border-0">
                                            <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Delete User</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                          </div>
                                          <div class="modal-body text-start">
                                            Delete user <strong>@item.Name</strong> completely? This cannot be undone.
                                          </div>
                                          <div class="modal-footer border-0">
                                            <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Cancel</button>
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-danger rounded-pill shadow-sm">Confirm Delete</button>
                                            </form>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
