@{ ViewData["Title"] = "Access Denied"; Layout = "_Layout"; }

<div class="container mt-5 fade-in text-center" style="max-width:500px; margin: 0 auto;">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-5">
            <div class="mb-4">
                <div class="denied-icon mx-auto mb-3">
                    <i class="bi bi-shield-x text-danger" style="font-size: 3.5rem;"></i>
                </div>
                <h2 class="fw-bold text-danger">Access Denied</h2>
                <p class="text-muted">You don't have permission to view this page.</p>
            </div>

            <div class="alert alert-warning border-0 rounded-3 text-start mb-4">
                <i class="bi bi-info-circle me-2"></i>
                If you believe this is a mistake, please contact your system administrator.
            </div>

            <div class="d-grid gap-2">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary rounded-pill">
                    <i class="bi bi-grid-1x2 me-2"></i>Go to Dashboard
                </a>
                <a asp-controller="Auth" asp-action="Logout" class="btn btn-outline-secondary rounded-pill">
                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .fade-in { animation: fadeIn 0.4s ease-in; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .denied-icon {
        width: 90px; height: 90px; border-radius: 50%;
        background: linear-gradient(135deg, #ffe0e0, #ffc0c0);
        display: flex; align-items: center; justify-content: center;
    }
</style>
